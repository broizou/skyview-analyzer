# Port d'écoute du serveur
PORT=3001

# Durée de vie du cache en minutes (les runs AROME sont publiés toutes les ~3h)
CACHE_TTL_MINUTES=60

# Origines autorisées (CORS) — séparer par virgule
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Clé API Météo-France (optionnel — pour accès direct AROME sans passer par Open-Meteo)
# Obtenir sur : https://portail-api.meteofrance.fr/
# MF_API_KEY=your_key_here
